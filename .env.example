# ── Database ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/hackathon
DB_USERNAME=hackathon
DB_PASSWORD=hackathon

# ── JWT (32자 이상 랜덤 문자열) ────────────────────────────
JWT_SECRET=change-this-to-a-random-32-plus-char-secret

# ── Claude AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS (프론트 도메인, 콤마 구분) ────────────────────────
# 기본값: http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── GitHub Container Registry ──────────────────────────────
GITHUB_REPOSITORY=org/repo
